# Go 服务监听地址。
SERVER_ADDR=:8080

# 支付宝 OpenAPI 网关地址。
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 支付宝开放平台应用 AppID。
ALIPAY_APP_ID=your_alipay_app_id

# 应用私钥 PEM 内容；部署时优先使用 ALIPAY_APP_PRIVATE_KEY_FILE。
ALIPAY_APP_PRIVATE_KEY=

# 应用私钥 PEM 文件路径；Docker Compose 默认挂载到 /run/secrets。
ALIPAY_APP_PRIVATE_KEY_FILE=/run/secrets/app_private_key.pem

# 支付宝公钥 PEM 内容；部署时优先使用 ALIPAY_PUBLIC_KEY_FILE。
ALIPAY_PUBLIC_KEY=

# 支付宝公钥 PEM 文件路径；Docker Compose 默认挂载到 /run/secrets。
ALIPAY_PUBLIC_KEY_FILE=/run/secrets/alipay_public_key.pem

# 在支付宝侧配置的公网异步通知回调地址。
ALIPAY_NOTIFY_URL=https://your-domain.example.com/alipay/v1/alipay/notify

# 支付宝接口版本。
ALIPAY_AI_COLLECT_VERSION=1.0

# 可选：服务商 / ISV 模式下的 app_auth_token。
ALIPAY_APP_AUTH_TOKEN=

# 可选：/v1/ai-collect/call 使用的旧版通用 AI 收接口方法名。
ALIPAY_AI_COLLECT_METHOD=

# 可选：凭证查询接口方法名；未设置时默认使用 ALIPAY_AI_COLLECT_METHOD。
ALIPAY_AI_COLLECT_CREDENTIAL_METHOD=

# Payment-Proof 支付证明验证接口方法名。
ALIPAY_PAYMENT_VERIFY_METHOD=alipay.aipay.agent.payment.verify

# 买家履约确认接口方法名。
ALIPAY_AI_COLLECT_FULFILLMENT_METHOD=alipay.aipay.agent.fulfillment.confirm

# /v1/paid-resource/check 使用的支付状态查询接口方法名。
ALIPAY_PAYMENT_STATUS_QUERY_METHOD=alipay.trade.query

# 支付状态持久化后端，可选 postgres 或 file。
PAYMENT_STATE_BACKEND=postgres

# 支付状态 Postgres DSN。请在私有 .env 中配置，禁止提交真实账号密码。
PAYMENT_STATE_DB_DSN=

# PAYMENT_STATE_BACKEND=file 时使用的本地状态文件路径。
PAYMENT_STATE_DB_PATH=/data/payment-state.json

# 卖家支付宝用户 ID / 2088 ID。
ALIPAY_SELLER_ID=2088xxxxxxxx

# 支付账单中展示的卖家名称。
ALIPAY_SELLER_NAME=测试商家

# 卖家应用 AppID；未设置时默认使用 ALIPAY_APP_ID。
ALIPAY_SELLER_APP_ID=

# Payment-Needed 中卖家唯一标识字段名。
ALIPAY_SELLER_UNIQUE_ID_KEY=seller_id

# 请求未提供 currency 时使用的默认币种。
ALIPAY_DEFAULT_CURRENCY=CNY

# Payment-Needed 中的支付网络标识。
ALIPAY_PAYMENT_NETWORK=alipay-a2a-prod

# 支付账单有效期，单位分钟。
ALIPAY_PAYMENT_PROOF_TTL_MINUTES=15
